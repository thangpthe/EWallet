<?xml version="1.0" encoding="utf-8"?>
<!-- item_point_history.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <View
        android:id="@+id/viewDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="#00C48C" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvPointDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nạp tiền 500.000đ"
            android:textColor="#0D0F3C"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPointDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="01/01/2025"
            android:textColor="#9EA8C2"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvPointDelta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+50 điểm"
        android:textColor="#00C48C"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>