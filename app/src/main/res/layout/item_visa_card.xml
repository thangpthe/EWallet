<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#EEF0FF"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Brand badge + card number row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <!-- Brand badge -->
            <TextView
                android:id="@+id/tvCardBrand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#EEF0FF"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="VISA"
                android:textColor="#3D5AFE"
                android:textSize="11sp"
                android:textStyle="bold"/>

            <!-- Masked card number -->
            <TextView
                android:id="@+id/tvCardNumber"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="**** **** **** 1234"
                android:textColor="#0D0F3C"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="monospace"/>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEF0FF"
            android:layout_marginBottom="10dp"/>

        <!-- Card holder + expiry -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvCardHolder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NGUYEN VAN A"
                    android:textColor="#0D0F3C"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvCardExpiry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Hết hạn: 12/26"
                    android:textColor="#8890B5"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- Action buttons -->
            <Button
                android:id="@+id/btnSelectCard"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Chọn"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:layout_marginEnd="6dp"
                android:visibility="gone"
                style="@style/Widget.MaterialComponents.Button"
                app:backgroundTint="#3D5AFE"
                app:cornerRadius="18dp"/>

            <Button
                android:id="@+id/btnDeleteCard"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Xoá"
                android:textSize="12sp"
                android:textColor="#EF4444"
                android:backgroundTint="@android:color/transparent"
                android:padding="0dp"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>